# Copy this file to .env for local development.
# DATABASE_ENCRYPTION_KEY is required. Generate a unique value for each local install.

ALLOWED_HOSTS=
DATABASE_CIPHER_COMPATIBILITY=4
DATABASE_CIPHER_PAGE_SIZE=4096
DATABASE_ENCRYPTION_KEY=replace-with-a-strong-passphrase
DATABASE_KDF_ITER=256000
DATABASE_NAME=db.sqlite3
DATABASE_TIMEOUT=20.0
DEBUG=1
DJANGO_ENV_EXAMPLE_FILE=.env.example
DJANGO_ENV_FILE=.env
DJANGO_SETTINGS_MODULE=config.settings
SECRET_KEY=django-insecure-development-only-change-me
