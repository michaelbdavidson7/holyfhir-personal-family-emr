# Copy this file to .env for local development.
# Leave DATABASE_ENCRYPTION_KEY blank to use the unencrypted local SQLite database.

DATABASE_NAME=db.sqlite3
DATABASE_TIMEOUT=20.0
DATABASE_ENCRYPTION_KEY=
DATABASE_ENCRYPTION_REQUIRED=0
DATABASE_CIPHER_PAGE_SIZE=4096
DATABASE_KDF_ITER=256000
DATABASE_CIPHER_COMPATIBILITY=4
